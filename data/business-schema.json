        "estimatedMinutes",
        "actualMinutes",
        "createdDate",
        "dueDate",
        "completedDate",
        "businessValue",
        "nextAction",
        "proofOfWorkId"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Backlog",
            "Planned",
            "In Progress",
            "Waiting",
            "Blocked",
            "Complete",
            "Deferred"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "Critical",
            "High",
            "Medium",
            "Low"
          ]
        },
        "owner": {
          "type": "string"
        },
        "estimatedMinutes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "actualMinutes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "createdDate": {
          "$ref": "#/$defs/dateString"
        },
        "dueDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "completedDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "businessValue": {
          "type": "string"
        },
        "nextAction": {
          "type": "string"
        },
        "proofOfWorkId": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "advertising": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentStatus",
        "monthlyBudget",
        "campaigns"

        "costPerLead": {
          "$ref": "#/$defs/money"
        },
        "sales": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "revenue": {
          "$ref": "#/$defs/money"
        },
        "lastReviewed": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "nextOptimization": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },

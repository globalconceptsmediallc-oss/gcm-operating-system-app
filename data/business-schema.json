{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://globalconceptsmedia.com/schemas/business-schema.json",
  "title": "GCM OS Business Record",
  "description": "Canonical data structure for every prospect, client, former client, and business managed inside the Global Concepts Media Operating System.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "businessId",
    "business",
    "relationship",
    "workspace",
    "currentPriorities",
    "workQueue",
    "advertising",
    "seo",
    "website",
    "socialMedia",
    "proofOfWork",
    "metrics",
    "results",
    "growthReviews",
    "caseStudy",
    "documents",
    "history",
    "metadata"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "businessId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Permanent lowercase slug used to identify the business."
    },
    "business": {
      "$ref": "#/$defs/business"
    },
    "relationship": {
      "$ref": "#/$defs/relationship"
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "currentPriorities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/priority"
      }
    },
    "workQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workItem"
      }
    },
    "advertising": {
      "$ref": "#/$defs/advertising"
    },
    "seo": {
      "$ref": "#/$defs/seo"
    },
    "website": {
      "$ref": "#/$defs/website"
    },
    "socialMedia": {
      "$ref": "#/$defs/socialMedia"
    },
    "proofOfWork": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proofOfWorkEntry"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metricSnapshot"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "growthReviews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/growthReview"
      }
    },
    "caseStudy": {
      "$ref": "#/$defs/caseStudy"
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/document"
      }
    },
    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/historyEntry"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "dateString": {
      "type": "string",
      "format": "date"
    },
    "dateTimeString": {
      "type": "string",
      "format": "date-time"
    },
    "money": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "percentage": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "business": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "legalName",
        "industry",
        "businessType",
        "website",
        "primaryMarket",
        "serviceAreas",
        "address",
        "phone",
        "email",
        "primaryContact",
        "summary",
        "tags"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "legalName": {
          "$ref": "#/$defs/nullableString"
        },
        "industry": {
          "type": "string",
          "minLength": 1
        },
        "businessType": {
          "type": "string",
          "enum": [
            "Local Service Business",
            "Retail",
            "Ecommerce",
            "Professional Service",
            "Home Service",
            "Multi-Location Business",
            "Other"
          ]
        },
        "website": {
          "$ref": "#/$defs/nullableString"
        },
        "primaryMarket": {
          "$ref": "#/$defs/nullableString"
        },
        "serviceAreas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "address": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "street",
            "city",
            "state",
            "postalCode",
            "country"
          ],
          "properties": {
            "street": {
              "$ref": "#/$defs/nullableString"
            },
            "city": {
              "$ref": "#/$defs/nullableString"
            },
            "state": {
              "$ref": "#/$defs/nullableString"
            },
            "postalCode": {
              "$ref": "#/$defs/nullableString"
            },
            "country": {
              "type": "string",
              "default": "United States"
            }
          }
        },
        "phone": {
          "$ref": "#/$defs/nullableString"
        },
        "email": {
          "$ref": "#/$defs/nullableString"
        },
        "primaryContact": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "role",
            "phone",
            "email"
          ],
          "properties": {
            "name": {
              "$ref": "#/$defs/nullableString"
            },
            "role": {
              "$ref": "#/$defs/nullableString"
            },
            "phone": {
              "$ref": "#/$defs/nullableString"
            },
            "email": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "summary": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recordType",
        "status",
        "entryMethod",
        "stage",
        "clientSince",
        "clientEnded",
        "monthlyAgreement",
        "billingStatus",
        "accountHealth",
        "accountHealthReason"
      ],
      "properties": {
        "recordType": {
          "type": "string",
          "enum": [
            "Prospect",
            "Client",
            "Former Client",
            "Previous Client",
            "Partner",
            "Internal"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "Inactive",
            "Archived",
            "Paused",
            "Lost",
            "Converted"
          ]
        },
        "entryMethod": {
          "type": "string",
          "enum": [
            "Cold Prospect",
            "Referral",
            "Business Snapshot",
            "Growth Review",
            "Existing Client",
            "Previous Client",
            "Manual Entry",
            "Other"
          ]
        },
        "stage": {
          "type": "string",
          "enum": [
            "Research",
            "Outreach",
            "Discovery",
            "Growth Review",
            "Proposal",
            "Onboarding",
            "Implementation",
            "Optimization",
            "Retention",
            "Paused",
            "Closed",
            "Archived"
          ]
        },
        "clientSince": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "clientEnded": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "monthlyAgreement": {
          "$ref": "#/$defs/money"
        },
        "billingStatus": {
          "type": "string",
          "enum": [
            "Current",
            "Past Due",
            "Not Applicable",
            "Needs Verification"
          ]
        },
        "accountHealth": {
          "type": "string",
          "enum": [
            "Strong",
            "Stable",
            "Needs Attention",
            "At Risk",
            "Paused",
            "Unknown"
          ]
        },
        "accountHealthReason": {
          "type": "string"
        }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentPriority",
        "nextAction",
        "nextActionReason",
        "nextReviewDate",
        "lastClientContact",
        "lastWorkDate",
        "owner",
        "workingNotes"
      ],
      "properties": {
        "currentPriority": {
          "type": "string"
        },
        "nextAction": {
          "type": "string"
        },
        "nextActionReason": {
          "type": "string"
        },
        "nextReviewDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "lastClientContact": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "lastWorkDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "owner": {
          "type": "string"
        },
        "workingNotes": {
          "type": "string"
        }
      }
    },
    "priority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category",
        "status",
        "priority",
        "owner",
        "businessValue",
        "dueDate",
        "nextAction"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Not Started",
            "Planned",
            "In Progress",
            "Waiting",
            "Blocked",
            "Complete",
            "Deferred"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "Critical",
            "High",
            "Medium",
            "Low"
          ]
        },
        "owner": {
          "type": "string"
        },
        "businessValue": {
          "type": "string"
        },
        "dueDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "nextAction": {
          "type": "string"
        }
      }
    },
    "workItem": {
      "type": "object",
      "additionalProperties": false,

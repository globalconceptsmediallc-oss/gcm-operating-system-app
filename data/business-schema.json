            "Active",
            "Partially Active",
            "Paused",
            "Not Running",
            "Needs Review"
          ]
        },
        "monthlyBudget": {
          "$ref": "#/$defs/money"
        },
        "campaigns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/campaign"
          }
        }
      }
    },
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "campaignName",
        "campaignType",
        "status",
        "objective",
        "offer",
        "landingPage",
        "dailyBudget",
        "monthlyBudget",
        "startDate",
        "endDate",
        "spend",
        "impressions",
        "clicks",
        "ctr",
        "conversions",
        "costPerLead",
        "sales",
        "revenue",
        "lastReviewed",
        "nextOptimization",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "platform": {
